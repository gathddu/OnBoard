services:
  postgres:
    image: postgres:16-alpine
    container_name: gestao-postgres
    environment:
      POSTGRES_DB: gestao_beneficiarios
      POSTGRES_USER: your_user
      POSTGRES_PASSWORD: your_password
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U dataprev_user -d gestao_beneficiarios"]
      interval: 10s
      timeout: 5s
      retries: 5

  beneficiarios-service:
    build: ./microservices/beneficiarios-service
    container_name: beneficiarios-service
    ports:
      - "8081:8081"
    environment:
      SPRING_DATASOURCE_URL: jdbc:postgresql://postgres:5432/gestao_beneficiarios
      SPRING_DATASOURCE_USERNAME: your_user
      SPRING_DATASOURCE_PASSWORD: your_password
    depends_on:
      postgres:
        condition: service_healthy

  consulta-service:
    build: ./microservices/consulta-service
    container_name: consulta-service
    ports:
      - "8082:8082"
    environment:
      BENEFICIARIOS_SERVICE_URL: http://beneficiarios-service:8081
    depends_on:
      - beneficiarios-service

  api-gateway:
    build: ./microservices/api-gateway
    container_name: api-gateway
    ports:
      - "8083:8083"
    environment:
      BENEFICIARIOS_SERVICE_URL: http://beneficiarios-service:8081
      CONSULTA_SERVICE_URL: http://consulta-service:8082
    depends_on:
      - beneficiarios-service
      - consulta-service

  frontend:
    build: ./frontend
    container_name: frontend
    ports:
      - "80:80"
    depends_on:
      - api-gateway

volumes:
  postgres_data:
